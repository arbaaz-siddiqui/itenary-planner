# =============================================================================
# Environment variables for the AI Itinerary Planner
# =============================================================================
# Copy to `.env` for local dev, or set these in your host's dashboard
# (Railway → Variables, Render → Environment) for deploys.
# `.env` itself is gitignored — never commit real secrets. Only this example
# file (with placeholders) is tracked.
#
# Only the LLM provider + its API key are REQUIRED for the app to boot.
# Everything else has a working default in settings.py; override only as needed.


# -----------------------------------------------------------------------------
# LLM provider  (REQUIRED)
# -----------------------------------------------------------------------------
# One of: openrouter | anthropic | selfhosted
LLM_PROVIDER=openrouter

# --- OpenRouter (used when LLM_PROVIDER=openrouter) ---
OPENROUTER_API_KEY=                                  # REQUIRED for openrouter
OPENROUTER_MODEL=mistralai/mistral-large-2411        # optional (this is the default)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1     # optional

# --- Anthropic / Claude (used when LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=                                   # REQUIRED for anthropic
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022           # optional

# --- Self-hosted vLLM (used when LLM_PROVIDER=selfhosted) ---
SELFHOSTED_BASE_URL=http://localhost:8000/v1         # optional
SELFHOSTED_API_KEY=EMPTY                             # optional
SELFHOSTED_MODEL=qwen/qwen-2.5-72b-instruct          # optional


# -----------------------------------------------------------------------------
# Booking API — ActivityLinker / Technoheaven (Gujjutours staging)
# -----------------------------------------------------------------------------
# Tenant IDs + base URL have defaults in settings.py; set only if rotated.
BOOKING_TOKEN=                                       # needed for live booking calls
# BOOKING_BASE_URL=https://stagingapi.gujjutours.com
# BOOKING_TENANT_ID=A29CD3EE-D050-A34A-3A53-3A20E4FAF5F3
# FLIGHT_LIST_TENANT_ID=E1047144-1A17-A2D5-E474-3A1DFEF15B7F
# FLIGHT_SEARCH_TENANT_ID=DB1EC027-BDEC-3EA4-EDE7-3A1BE86F63F6
# FLIGHT_LIST_CUSTOM_HOST=newinstance.activitylinker.com


# -----------------------------------------------------------------------------
# Twilio — WhatsApp surface
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886


# -----------------------------------------------------------------------------
# State persistence
# -----------------------------------------------------------------------------
# On Railway/Render with a mounted volume, point this at the volume path:
#   WHATSAPP_DB_PATH=/var/data/whatsapp_state.db
WHATSAPP_DB_PATH=whatsapp_state.db


# -----------------------------------------------------------------------------
# Currency — manual FX rates to INR (optional; defaults in settings.py)
# -----------------------------------------------------------------------------
# AED_TO_INR=23.0
# USD_TO_INR=84.0
# EUR_TO_INR=91.0
# GBP_TO_INR=107.0
# SGD_TO_INR=63.0


# -----------------------------------------------------------------------------
# Pricing — deposits, TCS, EMI (optional; defaults in settings.py)
# -----------------------------------------------------------------------------
# PAYMENT_BUFFER_DAYS=3
# DEPOSIT_PCT_120PLUS=20.0
# DEPOSIT_PCT_30_120=50.0
# DEPOSIT_PCT_30=100.0
# TCS_OVERSEAS_PACKAGE_PCT=20.0
# TCS_NON_PACKAGE_PCT=5.0
# TCS_NON_PACKAGE_THRESHOLD=700000
# EMI_TENURES=3,6,9,12


# -----------------------------------------------------------------------------
# HTTP client (optional; defaults in settings.py)
# -----------------------------------------------------------------------------
# HTTP_TIMEOUT_SECS=60
# HTTP_MAX_RETRIES=2
